<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="eComBox.Views.TimeCounter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    muxc:BackdropMaterial.ApplyToRootOrPageBackground="True"
    mc:Ignorable="d">

    <Grid MaxWidth="1000" HorizontalAlignment="Stretch" Margin="16,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="6,6,6,8"
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="2" Orientation="Horizontal">
                <CommandBar DefaultLabelPosition="Right">
                    <AppBarButton x:Uid="DatePage_NewButton" Icon="Add" Click="AddCard_Click" />
                    <AppBarButton x:Uid="DatePage_ClearButton" Icon="Delete" Click="ClearAll_Click" />
                    <AppBarSeparator />
                    <AppBarButton x:Uid="DatePage_ImportButton" Icon="Import" Click="Import_Click" />
                    <AppBarButton x:Uid="DatePage_ExportButton" Click="Export_Click">
                        <FontIcon Glyph="&#xEDE1;" />
                    </AppBarButton>

                    

                    <AppBarSeparator />
                    <AppBarToggleButton
                        x:Name="CardViewButton"
                        Label="卡片"
                        Click="CardView_Click">
                        <AppBarToggleButton.Icon>
                            <SymbolIcon Symbol="View" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>
                    <AppBarToggleButton
                        x:Name="ListViewButton"
                        Label="列表"
                        Click="ListView_Click">
                        <AppBarToggleButton.Icon>
                            <SymbolIcon Symbol="Bullets" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>
                    <AppBarSeparator />
                    <AppBarButton Label="排序">
                        Click="ListView_Click">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Sort" />
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="日期由近到远" Click="SortByDate_Click" />
                                <MenuFlyoutItem Text="A-Z 排序" Click="SortByName_Click" />
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>

                </CommandBar>
                <TextBlock
    Text="{Binding SortModeDisplayText}"
    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
    Style="{StaticResource CaptionTextBlockStyle}"
    VerticalAlignment="Center"
    TextWrapping="NoWrap"
    TextTrimming="CharacterEllipsis" />



            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <GridView
                x:Name="CardCountdownList"
                ItemsSource="{Binding Cards}"
                SelectionMode="None"
                IsItemClickEnabled="False"
                Background="Transparent"
                BorderThickness="0"
                IsSwipeEnabled="False"
                Visibility="{Binding CardViewVisibility}">
                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromHorizontalOffset="48" />
                        <ReorderThemeTransition />
                        <AddDeleteThemeTransition />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Loaded="CardItem_Loaded"
                            Unloaded="CardItem_Unloaded"
                            Width="300"
                            Margin="6"
                            Padding="0"
                            CornerRadius="12"
                            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Rectangle Fill="{Binding CardAccentBrush}" RadiusX="12" RadiusY="12" />

                                <StackPanel Grid.Row="1" Spacing="8" Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TaskName}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="WrapWholeWords" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Border
                                                Padding="6,2"
                                                CornerRadius="10"
                                                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                Visibility="{Binding NotificationMarkerVisibility}">
                                                <TextBlock Text="🔔" FontSize="12" VerticalAlignment="Center" />
                                            </Border>
                                            <Border
                                                Padding="8,2"
                                                CornerRadius="10"
                                                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                Visibility="{Binding RelativeHintVisibility}">
                                                <TextBlock Text="{Binding RelativeHintText}" FontSize="12" VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{Binding TargetDateText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding CountdownText}" Style="{StaticResource SubtitleTextBlockStyle}" />

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                        <Button Click="EditCard_Click" CommandParameter="{Binding}">
                                            <FontIcon Glyph="&#xE70F;" />
                                        </Button>
                                        <Button Click="PinCard_Click" CommandParameter="{Binding}">
                                            <FontIcon Glyph="&#xE718;" />
                                        </Button>
                                        <Button Click="DeleteCard_Click" CommandParameter="{Binding}">
                                            <FontIcon Glyph="&#xE74D;" />
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <ListView
                x:Name="CountdownList"
                ItemsSource="{Binding Cards}"
                SelectionMode="None"
                IsItemClickEnabled="False"
                Background="Transparent"
                BorderThickness="0"
                Visibility="{Binding ListViewVisibility}">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromHorizontalOffset="32" />
                        <ReorderThemeTransition />
                        <AddDeleteThemeTransition />
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Loaded="ListItem_Loaded"
                            Unloaded="ListItem_Unloaded"
                            Margin="0,0,0,10"
                            Padding="0"
                            CornerRadius="12"
                            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Rectangle Fill="{Binding CardAccentBrush}" RadiusX="12" RadiusY="12" />

                                <StackPanel Grid.Column="1" Spacing="6" Padding="16,14,14,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TaskName}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="WrapWholeWords" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Border
                                                Padding="6,2"
                                                CornerRadius="10"
                                                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                Visibility="{Binding NotificationMarkerVisibility}">
                                                <TextBlock Text="🔔" FontSize="12" VerticalAlignment="Center" />
                                            </Border>
                                            <Border
                                                Padding="8,2"
                                                CornerRadius="10"
                                                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                Visibility="{Binding RelativeHintVisibility}">
                                                <TextBlock Text="{Binding RelativeHintText}" FontSize="12" VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="{Binding TargetDateText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding CountdownText}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top" Margin="8">
                                    <Button Click="EditCard_Click" CommandParameter="{Binding}">
                                        <FontIcon Glyph="&#xE70F;" />
                                    </Button>
                                    <Button Click="PinCard_Click" CommandParameter="{Binding}">
                                        <FontIcon Glyph="&#xE718;" />
                                    </Button>
                                    <Button Click="DeleteCard_Click" CommandParameter="{Binding}">
                                        <FontIcon Glyph="&#xE74D;" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="8"
                Visibility="{Binding EmptyStateVisibility}">
                <FontIcon Glyph="&#xE823;" FontSize="40" HorizontalAlignment="Center" />
                <TextBlock Text="暂时没有倒计时，点击上方 + 新建一个目标日期。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
